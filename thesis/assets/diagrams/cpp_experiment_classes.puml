@startuml

struct RunParameters {
  ...
}
note bottom: Lásd Simulator osztálydiagram

struct ExperimentParameters {
  + RunParameters run_parameters
  + int runs
  + vector<RunParameters> expand()
}
ExperimentParameters o-- RunParameters

struct ExperimentSweepParameters {
  + ExperimentParameters starting_parameters
  + RunParameters delta
  + vector<RunParameters> expand()
}
ExperimentSweepParameters o-- ExperimentParameters
ExperimentSweepParameters o-- RunParameters

class RunStates {
  ...
}
note bottom: Lásd Simulator osztálydiagram

class "vector<RunStates>" { }
"vector<RunStates>" o-- RunStates
class ExperimentStates { }
ExperimentStates --|> "vector<RunStates>" : <<typedef>>

class "vector<ExperimentStates>" { }
"vector<ExperimentStates>" o-- ExperimentStates
class ExperimentSweepStates { }
ExperimentSweepStates --|> "vector<ExperimentStates>" : <<typedef>>

struct Measurement {
  + double min
  + double max
  + double avg
  + double std
  + double err
}
struct Statistics {
  + vector<int> entity_count_values
  + Measurement entity_count
  + vector<int> gene_count_values
  + Measurement gene_count
  + vector<int> species_count_values
  + Measurement species_count
}
Statistics o-- Measurement

class "vector<Statistics>" { }
"vector<Statistics>" o-- Statistics
class ExperimentStatistics { }
ExperimentStatistics --|> "vector<Statistics>" : <<typedef>>

class "vector<ExperimentStatistics>" { }
"vector<ExperimentStatistics>" o-- ExperimentStatistics
class ExperimentSweepStatistics { }
ExperimentSweepStatistics --|> "vector<ExperimentStatistics>" : <<typedef>>

class math <<namespace>> {
  + Measurement measure(values)
  + ExperimentStatistics measure(experimentParameters, experimentStates)
  + ExperimentSweepStatistics measure(experimentSweepParameters, experimentSweepStates)
}
math --> ExperimentSweepParameters
math --> ExperimentSweepStates
math --> ExperimentSweepStatistics

interface IOOutputWriter {
  + void write(params, statistics, &out_stream)
}
class CSVWriter {
  + void write(params, statistics, &out_stream)
}
class SVGWriter {
  + void write(params, statistics, &out_stream)
}

IOOutputWriter <|-- CSVWriter
IOOutputWriter <|-- SVGWriter

CSVWriter --> ExperimentSweepParameters
CSVWriter --> ExperimentSweepStatistics

SVGWriter --> ExperimentSweepParameters
SVGWriter --> ExperimentSweepStatistics

@enduml
